# Canonicalize: 301-redirect .html paths to clean URLs
/index.html       /            301
/strategy.html    /strategy    301
/guide.html       /guide       301
/notice.html      /notice      301
/insta.html       /insta       301
/blog/index.html  /blog        301

# /blog/<slug> automatically serves /blog/<slug>.html via Cloudflare's
# html_handling: "auto-trailing-slash" (default). No rewrite rule needed.
